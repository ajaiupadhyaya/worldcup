# API-Football (primary data source) — https://www.api-football.com
# Optional in dev: without it, the app falls back to ESPN automatically.
API_FOOTBALL_KEY=

# Optional external frame-analysis service. Leave empty to use the built-in free
# tactical checklist.
CV_SERVICE_URL=
# Shared secret between the Next app and the CV service. When set (recommended
# in any networked deploy), the CV /analyze-frame endpoint requires it and the
# Next proxy forwards it. Leave empty for local dev.
CV_SHARED_SECRET=

# Admin token gating the analysis `?force=1` cache bypass.
# Unset = the bypass is disabled for everyone (public callers are cache-first).
ADMIN_TOKEN=

# Canonical site URL — used for absolute OG image URLs so shared links unfurl
# correctly in production (falls back to VERCEL_URL, then localhost).
NEXT_PUBLIC_SITE_URL=

# Phase 5 rate limiting (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
